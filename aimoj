import streamlit as st
from transformers import pipeline

# Ovo je "magija" koja sprečava da AI stalno iznova učitava model
@st.cache_resource
def load_model():
    return pipeline("text-generation", model="distilgpt2")

generator = load_model()

st.set_page_config(page_title="AI Code Master", page_icon="⚡")

# UI - Izgleda moderno i čisto
st.title("🚀 AI Code Master Pro")
st.write("Napravljeno u Cloudu - Radi 24/7")

user_input = st.text_area("Unesi početak koda:", "def pozdrav():")

if st.button("GENERISI KOD"):
    with st.spinner('AI razmišlja...'):
        res = generator(user_input, max_length=100, num_return_sequences=1)
        st.code(res[0]['generated_text'], language='python')

st.sidebar.info("Ova aplikacija koristi Transformers biblioteku i hostovana je na Streamlit Cloud-u.")
